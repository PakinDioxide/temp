#include <bits/stdc++.h>
#define ll long long

using namespace std;

const int mxN = 555;

ll a[mxN][mxN], U[mxN][mxN], D[mxN][mxN], L[mxN][mxN], R[mxN][mxN];

int main() {
    ios::sync_with_stdio(0), cin.tie(0);
    int n, m; cin >> n >> m;
    for (int i = 1; i <= n; i++) for (int j = 1; j <= m; j++) cin >> a[i][j];
    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= m; j++) {
            L[i][j] = max(L[i][j-1] + a[i][j], a[i][j]);
        }
        for (int j = m; j >= 1; j--) {
            R[i][j] = max(R[i][j+1] + a[i][j], a[j][i]);
        }
    }
    for (int j = 1; j <= m; j++) {
        for (int i = 1; i <= n; i++) {
            U[i][j] = max(U[i-1][j] + a[i][j], a[i][j]);
        }
        for (int i = n; i >= 1; i--) {
            D[i][j] = max(D[i+1][j] + a[i][j], a[i][j]);
        }
    }
    ll ans = LLONG_MIN;
    for (int i = 1; i <= n; i++) for (int j = 1; j <= m; j++) ans = max(ans, max(0LL, max(L[i][j-1], R[i][j+1])) + max(0LL, max(U[i-1][j], D[i+1][j])) + a[i][j]);
    cout << ans << '\n';
}

