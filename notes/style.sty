\newcommand{\code}[1]{\texttt{#1}}
\newcommand{\ds}{\displaystyle}

\usepackage{etoolbox} % Add this to your preamble

\newcommand{\problemmeta}[3]{
    \par\noindent 
    \hspace*{1em}\begin{minipage}{\dimexpr\textwidth-2em}
        \small 
        \begin{tabular}{@{}l l}
            \textbf{Date}  & : #1 \\
            \ifblank{#2}{}{\textbf{Score} & : #2 \\} % Only renders if #2 is NOT empty
            \textbf{Tags}  & : \textcolor{blue!80!black}{\texttt{#3}}
        \end{tabular}
    \end{minipage}
}


\newcommand{\codelink}[1]{
